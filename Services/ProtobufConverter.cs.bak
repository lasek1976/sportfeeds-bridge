    }

    public static DiffKeyValue ToProtobuf(SportFeedsMongoToRabbitBridge.Phoenix.Models.Comparer.DiffKeyValue source)
    {
        return new DiffKeyValue
        {
            Key = source.Key ?? string.Empty,
            Value = source.Value ?? string.Empty
        };
    }
}
