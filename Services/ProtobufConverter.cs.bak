            DiffType = (DiffType)source.DiffType
        };

        if (source.DifferenceProperties != null)
        {
            foreach (var prop in source.DifferenceProperties)
            {
                result.DifferenceProperties.Add(ToProtobuf(prop));
            }
        }

        return result;
    }

