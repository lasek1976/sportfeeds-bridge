    public static DataProposalSuperComboClientDiff ToProtobuf(Phoenix.Models.Feeds.Diff.DataProposalSuperComboClientDiff source)
    {
        var result = new DataProposalSuperComboClientDiff
        {
            IdClient = source.IdClient,
